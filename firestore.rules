rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidSyncKey(key) {
      return key is string && key.size() >= 4 && key.size() <= 100 && key.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidUserConfig(data) {
      return data.keys().hasAll(['title', 'activeMonth', 'months']) 
          && data.keys().size() == 3
          && data.title is string && data.title.size() <= 100
          && data.activeMonth is string && data.activeMonth.size() <= 50
          && data.months is list && data.months.size() <= 50;
    }

    function isValidLessonCard(data) {
      return data.keys().hasAll(['id', 'icon', 'year', 'title', 'color', 'facts', 'month', 'notes', 'updatedAt', 'date', 'order', 'objectives'])
          && data.id is string && data.id.size() <= 100
          && data.icon is string && data.icon.size() <= 10
          && data.year is string && data.year.size() <= 100
          && data.title is string && data.title.size() <= 200
          && data.color is string && data.color.size() <= 20
          && data.facts is list && data.facts.size() <= 50
          && data.objectives is list && data.objectives.size() <= 50
          && data.month is string && data.month.size() <= 50
          && data.date is string && data.date.size() <= 10
          && data.notes is string && data.notes.size() <= 5000
          && data.order is number;
    }

    // Rules for Synced Profiles
    match /lesson_profiles/{syncKey} {
      match /config/{docId} {
        allow read: if isValidSyncKey(syncKey);
        allow write: if isValidSyncKey(syncKey) && isValidUserConfig(incoming());
      }
      
      match /cards/{cardId} {
        allow read: if isValidSyncKey(syncKey);
        allow write: if isValidSyncKey(syncKey) && isValidLessonCard(incoming());
      }
    }
  }
}
